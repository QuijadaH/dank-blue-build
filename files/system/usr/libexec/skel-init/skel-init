#!/usr/bin/env bash
set -euo pipefail

IMAGE_FILE="/usr/lib/dank-blue-build/image"

if [[ ! -f "$IMAGE_FILE" ]]; then
    exit 0
fi

IMAGE_ID="$(tr -d '[:space:]' < "$IMAGE_FILE")"

if ! bootc status | grep -Fq "$IMAGE_ID"; then
    exit 0
fi

SKEL="/etc/skel"
STAMP_REL=".local/state/dank-blue-build/skel-init-v1"
IGNORE_FILE="$SKEL/.skel-ignore"

# -------------------------
# Load skip list
# -------------------------
declare -a SKIP_LIST=()

if [[ -f "$IGNORE_FILE" ]]; then
    while IFS= read -r line; do
        line="$(echo "$line" | xargs)"

        # skip empty lines and comments
        [[ -z "$line" || "$line" == \#* ]] && continue

        SKIP_LIST+=("$line")
    done < "$IGNORE_FILE"
fi

# -------------------------
# Skip matching function
# -------------------------
should_skip() {
    local rel="$1"

    for pattern in "${SKIP_LIST[@]}"; do
        if [[ "$rel" == "$pattern" || "$rel" == "$pattern/"* ]]; then
            return 0
        fi
    done

    return 1
}

# -------------------------
# Iterate users
# -------------------------
awk -F: '$3 >= 1000 && $3 < 65534 { print $1 ":" $6 }' /etc/passwd |
while IFS=: read -r user home; do
    [[ -d "$home" ]] || continue

    stamp="$home/$STAMP_REL"

    # already initialized → skip user entirely
    if [[ -f "$stamp" ]]; then
        continue
    fi

    echo "Bootc skel init: $user"

    # copy top-level skel entries
    find "$SKEL" -mindepth 1 -maxdepth 1 -print0 |
    while IFS= read -r -d '' src; do
        rel="${src#$SKEL/}"
        dst="$home/$rel"

        # skip via declarative list
        if should_skip "$rel"; then
            continue
        fi

        # backup if exists
        if [[ -e "$dst" ]]; then
            ts=$(date +"%Y%m%d-%H%M%S")
            mv "$dst" "${dst}.bak.${ts}"
        fi

        mkdir -p "$(dirname "$dst")"
        cp -a "$src" "$dst"
        chown -R "$user:$user" "$dst"
    done

    # ensure stamp exists in user home
    mkdir -p "$(dirname "$stamp")"
    cp -a "$SKEL/$STAMP_REL" "$stamp"
    chown -R "$user:$user" "$home/.local/state/dank-blue-build"
done